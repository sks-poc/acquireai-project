PORT=8080
AZURE_OPENAI_API_KEY=replace_me
# Keys and Endpoint in Azure Portal (must be the OpenAI resource host, usually *.openai.azure.com)
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
# Optional: full base for Responses API if it differs (default = AZURE_OPENAI_ENDPOINT + /openai/v1)
# AZURE_OPENAI_RESPONSES_BASE_URL=https://YOUR-RESOURCE.openai.azure.com/openai/v1
AZURE_OPENAI_DEPLOYMENT=gpt-5.4-hackathlon
LLM_MODEL_NAME=gpt-5.4-hackathlon

# Optional live odds via https://the-odds-api.com/
ODDS_API_KEY=
ODDS_API_BASE=https://api.the-odds-api.com/v4
ODDS_SPORT_KEY=soccer_epl
ODDS_REGIONS=uk,eu
ODDS_MARKETS=h2h,totals
ODDS_FORMAT=decimal

# Frontend origin for CORS
CORS_ORIGIN=http://localhost:5173
