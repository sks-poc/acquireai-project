# Production environment template for Vercel/Cloud deploy.
# Fill the values marked replace_me before importing.

PORT=8080

# Azure OpenAI
AZURE_OPENAI_API_KEY=replace_me
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-5.4-hackathlon
LLM_MODEL_NAME=gpt-5.4-hackathlon
AZURE_OPENAI_API_VERSION=2024-12-01-preview
# Optional: full base if needed
# AZURE_OPENAI_RESPONSES_BASE_URL=https://YOUR-RESOURCE.openai.azure.com/openai/v1

# Optional live odds via https://the-odds-api.com/
ODDS_API_KEY=
ODDS_API_BASE=https://api.the-odds-api.com/v4
ODDS_SPORT_KEY=soccer_epl
ODDS_REGIONS=uk,eu
ODDS_MARKETS=h2h,totals
ODDS_FORMAT=decimal

# Kingmakers prematch navigation API
KINGMAKERS_BASE_URL=https://bff-gateway-int.kingmakers-account.workers.dev/api/sportsbook
KINGMAKERS_LOCALE=en
KINGMAKERS_CONTENT_LANGUAGE=en
KINGMAKERS_SCHEDULE_TIME_FRAME=4
KINGMAKERS_DISCRIMINATION_ID=19010101
KINGMAKERS_AREA_ID=1572
KINGMAKERS_DATE_FILTER_TYPE=1
KINGMAKERS_DATE_FILTER_RANGE=24
KINGMAKERS_PAGE_SIZE=50
KINGMAKERS_MAX_PAGES_PER_MARKET_TYPE=20
KINGMAKERS_INCLUDE_ODDS=true
KINGMAKERS_SPORTS_CONCURRENCY=4
KINGMAKERS_MARKET_TYPES_CONCURRENCY=4
KINGMAKERS_CACHE_TTL_MS=60000
KINGMAKERS_MAX_SPORTS=0

# Query-time Kingmakers tuning
KINGMAKERS_ENABLE_QUERY_ODDS=false
KINGMAKERS_QUERY_MAX_SPORTS=20
KINGMAKERS_QUERY_MAX_PAGES_PER_MARKET_TYPE=15
KINGMAKERS_QUERY_PAGE_SIZE=30
KINGMAKERS_QUERY_CONTEXT_EVENTS=200
KINGMAKERS_QUERY_SPORTS_CONCURRENCY=2
KINGMAKERS_QUERY_MARKET_TYPES_CONCURRENCY=2
KINGMAKERS_QUERY_CACHE_TTL_MS=60000

# Frontend origin for CORS (set to your Vercel app URL)
CORS_ORIGIN=https://YOUR-FRONTEND.vercel.app
